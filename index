                        <input type="number" id="entry-installments" required min="1" class="w-full bg-slate-900 border-slate-700 rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-indigo-500 outline-none" value="1">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Taxa de Juros Mensal (%)</label>
