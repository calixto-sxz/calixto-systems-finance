                <button onclick="closeModal('modal-add-carne')" class="text-slate-400 hover:text-white text-2xl">&times;</button>
            </div>
            <form id="form-carne" onsubmit="saveEntry(event)" class="p-8 space-y-6 max-h-[80vh] overflow-y-auto custom-scrollbar">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="col-span-full">
                        <label class="block text-sm font-medium text-slate-400 mb-2">Descrição / Nome do Cliente</label>
                        <input type="text" id="entry-name" required class="w-full bg-slate-900 border-slate-700 rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="Ex: Empréstimo João da Silva">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Tipo de Registro</label>
                        <select id="entry-type" class="w-full bg-slate-900 border-slate-700 rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-indigo-500 outline-none">
                            <option value="pessoal">Gasto Pessoal</option>
                            <option value="cliente">Parcelamento de Cliente</option>
                            <option value="emprestimo">Empréstimo Concedido</option>
                            <option value="investimento">Investimento</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Valor Total (R$)</label>
                        <input type="number" step="0.01" id="entry-value" required class="w-full bg-slate-900 border-slate-700 rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="0,00">
