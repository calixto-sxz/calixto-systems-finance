        <div class="p-6">
            <div class="flex items-center gap-3 mb-8">
                <div class="w-10 h-10 bg-indigo-600 rounded-lg flex items-center justify-center shadow-lg shadow-indigo-500/20">
                    <i class="fas fa-chart-line text-white text-xl"></i>
                </div>
                <h1 class="text-xl font-bold tracking-tight">Calixto <span class="text-indigo-500">Systems</span></h1>
            </div>

            <nav class="space-y-1">
                <button onclick="switchTab('dashboard')" class="nav-link w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-slate-800 text-slate-400 hover:text-white" id="nav-dashboard">
                    <i class="fas fa-th-large w-5"></i> Dashboard
                </button>
                <button onclick="switchTab('carnes')" class="nav-link w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-slate-800 text-slate-400 hover:text-white" id="nav-carnes">
                    <i class="fas fa-file-invoice-dollar w-5"></i> Carnês e Parcelas
                </button>
                <button onclick="switchTab('emprestimos')" class="nav-link w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-slate-800 text-slate-400 hover:text-white" id="nav-emprestimos">
                    <i class="fas fa-hand-holding-usd w-5"></i> Empréstimos
                </button>
                <button onclick="switchTab('calculadora')" class="nav-link w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-slate-800 text-slate-400 hover:text-white" id="nav-calculadora">
                    <i class="fas fa-calculator w-5"></i> Calculadora
                </button>
            </nav>
        </div>

        <div class="mt-auto p-6">
            <div class="bg-slate-800/50 rounded-2xl p-4 border border-slate-700">
                <p class="text-xs text-slate-400 mb-2">Suporte Premium</p>
                <p class="text-sm font-medium">Calixto Systems v1.0</p>
