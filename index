    <script>
        // --- DATA & STATE ---
        let carnes = JSON.parse(localStorage.getItem('calixto_data')) || [];
        let currentFilter = 'todos';
        let searchQuery = '';

        // --- CORE FUNCTIONS ---
        function saveData() {
            localStorage.setItem('calixto_data', JSON.stringify(carnes));
            updateStats();
            renderLists();
        }

        function saveEntry(e) {
            e.preventDefault();
            const name = document.getElementById('entry-name').value;
            const type = document.getElementById('entry-type').value;
            const value = parseFloat(document.getElementById('entry-value').value);
            const count = parseInt(document.getElementById('entry-installments').value);
            const interest = parseFloat(document.getElementById('entry-interest').value) || 0;
            const startDate = document.getElementById('entry-date').value;
            const freq = document.getElementById('entry-frequency').value;

            // Calculation
            const totalWithInterest = value * (1 + (interest / 100));
            const parcelValue = totalWithInterest / count;
            
            const installments = [];
            let lastDate = new Date(startDate + 'T00:00:00');

            for (let i = 1; i <= count; i++) {
                const dueDate = new Date(lastDate);
                if (i > 1) {
                    if (freq === 'diario') dueDate.setDate(dueDate.getDate() + 1);
                    else if (freq === 'semanal') dueDate.setDate(dueDate.getDate() + 7);
                    else if (freq === 'mensal') dueDate.setMonth(dueDate.getMonth() + 1);
                    else if (freq === 'anual') dueDate.setFullYear(dueDate.getFullYear() + 1);
                }
                
                installments.push({
                    id: Date.now() + i,
                    dueDate: dueDate.toISOString().split('T')[0],
                    value: parcelValue,
                    paid: false
                });
                lastDate = dueDate;
            }

            const newCarne = {
                id: Date.now(),
                name,
                type,
                originalValue: value,
                totalValue: totalWithInterest,
                interestRate: interest,
                installmentsCount: count,
                startDate,
                frequency: freq,
                installments,
                createdAt: new Date().toISOString()
            };

            carnes.push(newCarne);
            saveData();
            closeModal('modal-add-carne');
            e.target.reset();
        }

        function deleteCarne(id) {
            if (confirm('Deseja realmente excluir este registro?')) {
                carnes = carnes.filter(c => c.id !== id);
                saveData();
            }
        }

        function toggleParcela(carneId, parcelaId) {
            const carne = carnes.find(c => c.id === carneId);
            if (carne) {
                const p = carne.installments.find(i => i.id === parcelaId);
                if (p) {
                    p.paid = !p.paid;
                    saveData();
                    showDetails(carneId); // Refresh details modal
                }
            }
        }

        // --- UTILS ---
        const formatBRL = (val) => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(val);
        
        function getStatus(dateStr, isPaid) {
            if (isPaid) return { text: 'PAGO', color: 'bg-emerald-500/20 text-emerald-400', icon: 'fa-check-circle' };
            const today = new Date();
            today.setHours(0,0,0,0);
            const due = new Date(dateStr + 'T00:00:00');
            due.setHours(0,0,0,0);

            if (due < today) return { text: 'ATRASADO', color: 'bg-rose-500/20 text-rose-400', icon: 'fa-exclamation-circle' };
            if (due.getTime() === today.getTime()) return { text: 'VENCE HOJE', color: 'bg-amber-500/20 text-amber-400', icon: 'fa-clock' };
            return { text: 'EM DIA', color: 'bg-blue-500/20 text-blue-400', icon: 'fa-calendar' };
        }

        // --- UI RENDERING ---
        function updateStats() {
            const totalEmprestado = carnes.filter(c => c.type === 'emprestimo').reduce((acc, c) => acc + c.originalValue, 0);
            const totalReceber = carnes.reduce((acc, c) => acc + c.totalValue, 0);
            
            let totalRecebido = 0;
            let totalAberto = 0;
            
            carnes.forEach(c => {
                c.installments.forEach(p => {
                    if (p.paid) totalRecebido += p.value;
                    else totalAberto += p.value;
                });
            });

            document.getElementById('stat-total-emprestado').innerText = formatBRL(totalEmprestado);
            document.getElementById('stat-total-receber').innerText = formatBRL(totalReceber);
            document.getElementById('stat-total-recebido').innerText = formatBRL(totalRecebido);
            document.getElementById('stat-total-aberto').innerText = formatBRL(totalAberto);

            // Dashboard Upcoming
            const allInstallments = [];
            carnes.forEach(c => {
                c.installments.forEach(p => {
                    if (!p.paid) allInstallments.push({ ...p, parentName: c.name });
                });
            });

            allInstallments.sort((a, b) => new Date(a.dueDate) - new Date(b.dueDate));
            const upcomingHtml = allInstallments.slice(0, 5).map(p => {
                const status = getStatus(p.dueDate, false);
                return `
                    <div class="bg-slate-800 p-4 rounded-xl border border-slate-700 flex items-center justify-between card-hover">
                        <div>
                            <p class="font-bold text-sm">${p.parentName}</p>
                            <p class="text-xs text-slate-400">${new Date(p.dueDate + 'T00:00:00').toLocaleDateString('pt-BR')}</p>
                        </div>
                        <div class="text-right">
                            <p class="font-bold text-indigo-400">${formatBRL(p.value)}</p>
                            <span class="status-badge ${status.color}">${status.text}</span>
                        </div>
                    </div>
                `;
            }).join('');
            document.getElementById('upcoming-list').innerHTML = upcomingHtml || '<p class="text-slate-500 text-sm">Nenhuma parcela pendente.</p>';

            // Category Stats
            const types = ['pessoal', 'cliente', 'emprestimo', 'investimento'];
            const categoryHtml = types.map(t => {
                const count = carnes.filter(c => c.type === t).length;
                const total = carnes.filter(c => c.type === t).reduce((acc, c) => acc + c.totalValue, 0);
                const percentage = carnes.length > 0 ? (count / carnes.length) * 100 : 0;
                return `
                    <div class="space-y-1">
                        <div class="flex justify-between text-xs mb-1">
                            <span class="capitalize text-slate-300 font-medium">${t}</span>
                            <span class="text-slate-400">${formatBRL(total)}</span>
                        </div>
                        <div class="w-full bg-slate-700 h-1.5 rounded-full overflow-hidden">
                            <div class="bg-indigo-500 h-full" style="width: ${percentage}%"></div>
                        </div>
                    </div>
                `;
            }).join('');
            document.getElementById('category-stats').innerHTML = categoryHtml;
        }

        function renderLists() {
            const grid = document.getElementById('carnes-grid');
            const tableBody = document.getElementById('loans-table-body');
            const sortBy = document.getElementById('sort-carnes').value;

            // Filtering
            let filtered = carnes.filter(c => {
                const matchesSearch = c.name.toLowerCase().includes(searchQuery.toLowerCase());
                const matchesType = currentFilter === 'todos' || c.type === currentFilter;
                return matchesSearch && matchesType;
            });

            // Sorting
            if (sortBy === 'newest') filtered.sort((a, b) => b.id - a.id);
            else if (sortBy === 'value-desc') filtered.sort((a, b) => b.totalValue - a.totalValue);
            else if (sortBy === 'name') filtered.sort((a, b) => a.name.localeCompare(b.name));

            // Render Carnes Grid
            grid.innerHTML = filtered.map(c => {
                const paidCount = c.installments.filter(i => i.paid).length;
                const progress = (paidCount / c.installmentsCount) * 100;
                return `
                    <div class="bg-slate-800 rounded-2xl border border-slate-700 overflow-hidden shadow-lg card-hover">
                        <div class="p-5 border-b border-slate-700 flex justify-between items-start">
                            <div>
                                <span class="text-[10px] uppercase font-bold tracking-widest text-indigo-400">${c.type}</span>
                                <h4 class="font-bold text-lg truncate w-40">${c.name}</h4>
                            </div>
                            <button onclick="deleteCarne(${c.id})" class="text-slate-500 hover:text-rose-500 transition-colors">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </div>
                        <div class="p-5 space-y-4">
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-xs text-slate-500">Valor Total</p>
                                    <p class="text-xl font-bold">${formatBRL(c.totalValue)}</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-xs text-slate-500">${c.installmentsCount} parcelas</p>
                                    <p class="text-sm font-medium text-slate-300">${formatBRL(c.totalValue / c.installmentsCount)}/mês</p>
                                </div>
                            </div>
                            <div class="space-y-1">
                                <div class="flex justify-between text-xs">
                                    <span class="text-slate-400">Progresso de pagamento</span>
                                    <span class="text-indigo-400 font-bold">${paidCount}/${c.installmentsCount}</span>
                                </div>
                                <div class="w-full bg-slate-900 h-2 rounded-full overflow-hidden">
                                    <div class="bg-indigo-500 h-full transition-all duration-500" style="width: ${progress}%"></div>
                                </div>
                            </div>
                            <button onclick="showDetails(${c.id})" class="w-full bg-slate-700 hover:bg-slate-600 py-2.5 rounded-xl text-sm font-bold transition-all">
                                Ver Parcelas
                            </button>
                        </div>
                    </div>
                `;
            }).join('');

            // Render Loans Table
            const loans = carnes.filter(c => c.type === 'emprestimo');
            tableBody.innerHTML = loans.map(l => {
                const paid = l.installments.filter(i => i.paid).length;
                const profit = l.totalValue - l.originalValue;
                const isLate = l.installments.some(p => !p.paid && new Date(p.dueDate + 'T00:00:00') < new Date().setHours(0,0,0,0));
                
                return `
                    <tr class="hover:bg-slate-800/50 transition-colors">
                        <td class="px-6 py-4 font-medium text-slate-200">${l.name}</td>
                        <td class="px-6 py-4 text-slate-400">${formatBRL(l.originalValue)}</td>
                        <td class="px-6 py-4 text-emerald-400 font-bold">${formatBRL(l.totalValue)} <span class="text-[10px] text-slate-500 block">+${formatBRL(profit)} lucro</span></td>
                        <td class="px-6 py-4">
                            <span class="text-xs font-medium">${paid} / ${l.installmentsCount}</span>
                        </td>
                        <td class="px-6 py-4">
                            ${paid === l.installmentsCount 
                                ? '<span class="status-badge bg-emerald-500/20 text-emerald-400">QUITADO</span>' 
                                : isLate 
                                    ? '<span class="status-badge bg-rose-500/20 text-rose-400">EM ATRASO</span>'
                                    : '<span class="status-badge bg-blue-500/20 text-blue-400">EM DIA</span>'
                            }
                        </td>
                        <td class="px-6 py-4 text-indigo-400 cursor-pointer font-bold hover:underline" onclick="showDetails(${l.id})">
                            Gerenciar
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function showDetails(id) {
            const carne = carnes.find(c => c.id === id);
            if (!carne) return;

            document.getElementById('details-title').innerText = carne.name;
            document.getElementById('details-subtitle').innerText = `${carne.installmentsCount} parcelas de ${formatBRL(carne.totalValue/carne.installmentsCount)}`;
            
            let paidTotal = 0;
            let remainingTotal = 0;

            const listHtml = carne.installments.map((p, idx) => {
                const status = getStatus(p.dueDate, p.paid);
                if (p.paid) paidTotal += p.value; else remainingTotal += p.value;
                
                return `
                    <div class="bg-slate-900 border border-slate-700 p-4 rounded-xl flex items-center justify-between">
                        <div class="flex items-center gap-4">
                            <div class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center text-xs font-bold text-slate-500">${idx + 1}</div>
                            <div>
                                <p class="text-sm font-bold text-slate-200">${new Date(p.dueDate + 'T00:00:00').toLocaleDateString('pt-BR')}</p>
                                <span class="status-badge ${status.color} mt-1 inline-block">${status.text}</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-6">
                            <p class="font-bold text-slate-300">${formatBRL(p.value)}</p>
                            <button onclick="toggleParcela(${carne.id}, ${p.id})" class="w-10 h-10 rounded-xl ${p.paid ? 'bg-emerald-600 text-white' : 'bg-slate-700 text-slate-400'} flex items-center justify-center transition-all hover:scale-105 shadow-lg">
                                <i class="fas ${p.paid ? 'fa-check' : 'fa-wallet'}"></i>
                            </button>
                        </div>
                    </div>
                `;
            }).join('');

            document.getElementById('installments-list').innerHTML = listHtml;
            document.getElementById('details-paid-total').innerText = formatBRL(paidTotal);
            document.getElementById('details-remaining-total').innerText = formatBRL(remainingTotal);
            openModal('modal-details');
        }

        // --- NAVIGATION & TABS ---
        function switchTab(tab) {
            // Hide all views
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            // Remove active style from nav
            document.querySelectorAll('.nav-link').forEach(l => {
                l.classList.remove('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-500/20');
                l.classList.add('text-slate-400');
            });

            // Show current view
            document.getElementById(`view-${tab}`).classList.remove('hidden');
            document.getElementById(`nav-${tab}`).classList.add('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-500/20');
            document.getElementById(`nav-${tab}`).classList.remove('text-slate-400');
            
            document.getElementById('current-tab-title').innerText = tab.charAt(0).toUpperCase() + tab.slice(1);
        }

        function handleSearch(val) {
            searchQuery = val;
            renderLists();
        }

        function filterType(type) {
            currentFilter = type;
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('bg-indigo-600');
                btn.classList.add('bg-slate-800');
            });
            document.querySelector(`[data-type="${type}"]`).classList.add('bg-indigo-600');
            renderLists();
        }

        // --- MODALS ---
        function openModal(id) {
            document.getElementById(id).classList.remove('hidden');
        }

        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }

        // --- CALCULATOR ---
        function calculateFinance() {
            const valor = parseFloat(document.getElementById('calc-valor').value);
            const taxa = parseFloat(document.getElementById('calc-taxa').value);
            const tempo = parseFloat(document.getElementById('calc-tempo').value);

            if (!valor || !taxa || !tempo) return alert('Preencha todos os campos!');

            const juros = valor * (taxa / 100) * tempo;
            const montante = valor + juros;

            document.getElementById('res-juros').innerText = formatBRL(juros);
            document.getElementById('res-montante').innerText = formatBRL(montante);
            document.getElementById('calc-result').classList.remove('hidden');
        }

        // --- INITIALIZATION ---
        window.onload = () => {
            // Set default date to today
            document.getElementById('entry-date').valueAsDate = new Date();
            updateStats();
            renderLists();
            switchTab('dashboard');
        };
    </script>
</body>
</html>
