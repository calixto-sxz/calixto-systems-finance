    <!-- Modal Adicionar Carnê/Empréstimo -->
    <div id="modal-add-carne" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-slate-800 w-full max-w-2xl rounded-3xl border border-slate-700 shadow-2xl modal-enter overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-700 flex items-center justify-between">
