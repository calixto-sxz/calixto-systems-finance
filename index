    <!-- Modal Detalhes Parcelas -->
    <div id="modal-details" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-slate-800 w-full max-w-3xl rounded-3xl border border-slate-700 shadow-2xl modal-enter overflow-hidden flex flex-col max-h-[90vh]">
            <div class="px-8 py-6 border-b border-slate-700 flex items-center justify-between">
                <div>
                    <h3 id="details-title" class="text-xl font-bold">Cronograma de Pagamento</h3>
                    <p id="details-subtitle" class="text-sm text-slate-400"></p>
                </div>
                <button onclick="closeModal('modal-details')" class="text-slate-400 hover:text-white text-2xl">&times;</button>
            </div>
            <div class="p-8 flex-1 overflow-y-auto custom-scrollbar">
                <div id="installments-list" class="space-y-3">
                    <!-- JS Inject -->
                </div>
            </div>
            <div class="px-8 py-4 bg-slate-900/50 border-t border-slate-700 flex justify-between items-center">
                <div class="flex gap-4">
                    <div class="text-xs text-slate-400">Total Pago: <span id="details-paid-total" class="text-emerald-400 font-bold text-sm">R$ 0,00</span></div>
                    <div class="text-xs text-slate-400">Restante: <span id="details-remaining-total" class="text-rose-400 font-bold text-sm">R$ 0,00</span></div>
                </div>
                <button onclick="closeModal('modal-details')" class="bg-indigo-600 text-sm px-6 py-2 rounded-lg font-bold">Fechar</button>
            </div>
        </div>
